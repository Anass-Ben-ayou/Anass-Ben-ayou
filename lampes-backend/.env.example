APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
FRONTEND_URL=http://localhost:3000
JWT_SECRET=
JWT_TTL_MINUTES=120
AUTH_COOKIE_NAME=access_token
CSRF_COOKIE_NAME=XSRF-TOKEN
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
PAYMENT_PROVIDER=stripe
PAYMENT_CURRENCY=mad
STRIPE_CURRENCY=mad
CHECKOUT_SUCCESS_URL=http://localhost:3000/checkout/success
CHECKOUT_CANCEL_URL=http://localhost:3000/checkout/failed
CHECKOUT_PENDING_URL=http://localhost:3000/checkout/pending
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_API_BASE=https://api.stripe.com/v1
STRIPE_API_VERSION=2025-02-24.acacia
STRIPE_TEST_TOKEN=tok_visa
STRIPE_TEST_PAYMENT_METHOD=pm_card_visa
STRIPE_TEST_MODE_ONLY=true
DEMO_CARD_ENABLED=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
